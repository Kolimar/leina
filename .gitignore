# Dependencies
node_modules/

# Build output (regenerated by `npm run build`)
dist/

# Test coverage
coverage/

# Bilingual docs site (regenerated by `npm run docs:site:build`, deployed by CI)
site/

# leina runtime artifacts (per-project graph db + manifest)
.leina/

# npm pack artifacts
*.tgz

# Claude Code local (per-machine) settings
.claude/settings.local.json

# OS / editor cruft
.DS_Store
*.log
npm-debug.log*

# Local env
.env
.env.local

# Rust build output (test/fixtures/scip/rust — regenerated by `cargo build`,
# never needed to run the committed index.scip gate)
test/fixtures/scip/rust/target/

# leina:ignore:start
.leina/*
!.leina/config.json
!.leina/memory-export.jsonl
# leina:ignore:end
